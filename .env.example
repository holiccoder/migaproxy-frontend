# Browser-facing app origin (Next.js dev server)
NEXT_PUBLIC_BASE_URL=http://localhost:4002
NEXT_PUBLIC_APP_BASE_URL=http://localhost:4002

# Single backend base URL for all API endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Search engine spiders toggle (true = allow, false = block)
NEXT_PUBLIC_ALLOW_SEARCH_ENGINE_SPIDERS=false
