# Browser-facing app origin (Next.js dev server)
NEXT_PUBLIC_BASE_URL=http://localhost:4002
NEXT_PUBLIC_APP_BASE_URL=http://localhost:4002

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ALLOW_SEARCH_ENGINE_SPIDERS=false

# Server-side proxy target for Next.js API/storage proxy routes.
# Must be reachable by Node.js. Start backend with: php artisan serve --host=127.0.0.1 --port=8001
API_PROXY_URL=http://127.0.0.1:8000
